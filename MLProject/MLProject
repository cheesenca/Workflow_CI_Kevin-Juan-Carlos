name: fraud-detection

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      contamination: {type: float, default: 0.05}
      random_state: {type: int, default: 42}
      n_estimators: {type: int, default: 100}
      dataset: {type: str, default: "bank_transactions_preprocessing.csv"}
    command: "python modeling.py --contamination {contamination} --random_state {random_state} --n_estimators {n_estimators} --dataset {dataset}"
